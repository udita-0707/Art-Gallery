{
  "name": "spectrum-art-platform",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:server": "npm run db:generate --workspace=@spectrum/database && npm run build --workspace=@spectrum/server",
    "build:web": "npm run build --workspace=@spectrum/web",
    "build:admin": "npm run build --workspace=@spectrum/admin"
  },
  "devDependencies": {
    "turbo": "^2.9.16"
  }
}
